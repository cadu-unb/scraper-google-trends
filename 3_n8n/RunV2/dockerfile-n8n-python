# Estágio 1: Usa o Python compilado oficialmente para Alpine (compatível com o n8n)
FROM python:3.11-alpine AS python-base

# Estágio 2: Volta para a sua imagem do n8n
FROM n8nio/n8n:2.29.1

USER root

# Copia os binários do Python já compilados para Alpine diretamente para o n8n
COPY --from=python-base /usr/local/ /usr/local/

# Copia a biblioteca nativa exigida pelo modulo `_ctypes` usado por pandas/pytrends
COPY --from=python-base /usr/lib/libffi.so.8* /usr/lib/

# Troca de volta para o usuário padrão do n8n
USER node

# Instala o pipx de forma limpa usando o Python copiado
RUN python3 -m pip install --user --break-system-packages pipx

# Instala as dependencias usadas pelos scripts Python chamados pelo n8n
COPY 1_src/keyword_research_app/requirements.txt /tmp/keyword-research-requirements.txt
RUN python3 -m pip install --user --break-system-packages \
    -r /tmp/keyword-research-requirements.txt

# Garante o path do pipx configurado no sistema
ENV PATH="/home/node/.local/bin:$PATH"
